# --- Database ---
# Postgres connection string. Matches the service in docker-compose.yml.
DATABASE_URL=postgres://admin:password123@localhost:5432/life_planner

# --- AI providers ---
# Google Gemini API key (document parsing, embeddings, study guides, refinement).
GEMINI_API_KEY=your-gemini-api-key
# Groq API key (Whisper audio transcription).
GROQ_API_KEY=your-groq-api-key

# --- API security (Phase A1) ---
# Shared bearer token required by the Express API. Leave blank to disable auth
# (NOT recommended outside local development).
API_AUTH_TOKEN=change-me-to-a-long-random-string
# 32-byte (64 hex char) key used to encrypt credentials at rest in sensor_configs.
# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=

# --- Pipeline cost guardrails (Phase E0) ---
# Approximate per-run token budget for the AI content-refinement pass. The
# engine stops refining once this is reached. Use the dry-run estimate
# (POST /api/refine?dryRun=true) to size a run before spending tokens.
REFINE_MAX_TOKENS=200000

# --- AI Agents (Phase E) ---
# When 'true', the hourly cron runs the autonomous Orchestrator agent after the
# sensor sweep. The Orchestrator can delegate destructive actions, but every
# such action is still gated behind human approval in the Face widget. Left off
# by default so no autonomous actions run until you opt in.
ENABLE_ORCHESTRATOR=false

# --- Logging ---
LOG_LEVEL=info
