    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:migrate-data": "tsx src/scripts/migrate-pglite-to-postgres.ts",
    "debug:canvas": "tsx src/scripts/debug-canvas.ts",
    "debug:agents": "tsx src/scripts/debug-agents.ts",
    "mcp:postgres": "tsx src/mcp/postgres.ts",
    "mcp:uni-sensors": "tsx src/mcp/uni-sensors.ts",
    "mcp:actions": "tsx src/mcp/actions.ts"
  },
  "keywords": [],
  "author": "",
